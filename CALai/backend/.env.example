# Database
DATABASE_URL=postgresql+asyncpg://rmuser:rmpass@localhost:5432/resumematch

# Redis
REDIS_URL=redis://localhost:6379

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
